          "path": ["api", "v1", "meals", "{{mealId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 204', function () { pm.response.to.have.status(204); });",

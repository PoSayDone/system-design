            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/v1/meals/{meal_id} (404 after delete)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/meals/{{mealId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "meals", "{{mealId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404', function () { pm.response.to.have.status(404); });",
              "pm.test('Error body contains detail', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.detail).to.eql('Meal not found');",
              "});"
            ]
          }
        }
      ]
    }
  ],
